# ─── Database ───────────────────────────────────────────────────────────────
DB_URL=jdbc:sqlserver://localhost:1433;databaseName=portal_db;encrypt=false;trustServerCertificate=true
DB_USERNAME=sa
DB_PASSWORD=your_db_password

# ─── JWT ─────────────────────────────────────────────────────────────────────
# MUST be at least 32 characters (256 bits) for HS256. NEVER hardcode.
JWT_SECRET_KEY=change-this-to-a-secure-random-256bit-key-in-production
JWT_EXPIRATION=1800

# ─── JPA ─────────────────────────────────────────────────────────────────────
# create-drop (dev) | update (staging) | validate (prod)
DDL_AUTO=update

# ─── Initial Admin Account ───────────────────────────────────────────────────
ADMIN_INITIAL_EMAIL=admin@bit.com
ADMIN_INITIAL_PASSWORD=Admin1234!

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
